# Configuración de la Base de Datos
DATABASE_URL=postgresql://user:password@localhost:5432/clienteos

# Configuración JWT
JWT_SECRET=tu-secret-key-super-segura-aqui
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# Configuración Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://tu-endpoint.openai.azure.com/
AZURE_OPENAI_KEY=tu-api-key-aqui
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_MODEL=gpt-4

# Configuración Stripe
STRIPE_SECRET_KEY=sk_test_tu-key-aqui
STRIPE_PUBLISHABLE_KEY=pk_test_tu-key-aqui
STRIPE_WEBHOOK_SECRET=whsec_tu-secret-aqui

# Configuración WhatsApp Business
WA_ACCESS_TOKEN=tu-token-whatsapp
WA_PHONE_NUMBER_ID=tu-numero-id
WA_VERIFY_TOKEN=tu-token-verificacion
WA_WEBHOOK_URL=https://tu-dominio.com/api/whatsapp/webhook

# Configuración General
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ENABLE_CORS=true
DEBUG=true